{{/*
  systemd-unit redis_exporter. Контекст рендера (docs/templating.md §3.2):
    .vars  — явно переданные core.file.rendered (bin_dir, listen, redis_addr,
             extra_args);
    .self  — стабильные факты хоста (здесь не используются).

  Подключение к Redis — через unix-сокет: --redis.addr=unix:///<path>
  (.vars.redis_addr уже содержит префикс unix://, собран в scenario из
   input.redis_socket).

  СЕРВИС-АККАУНТ. Выделенный системный пользователь redis-exporter (User/Group),
  НЕ DynamicUser — осознанно, в отличие от эталонной destiny redis-exporter. Этот
  сервис подключается к УЖЕ работающему Redis (возможно, чужому/без auth), сам
  Redis НЕ ставит (см. README §«Допущения»), поэтому остаётся на инлайн-модели с
  ручным core.user. redis-exporter состоит в supplementary-группе redis (заводится
  шагом core.user в scenario, до старта) ради group-доступа к unix-сокету (типично
  unixsocketperm 770, owner redis:redis). DynamicUser тут не подходит: эфемерный
  UID systemd не входил бы в группу redis → сокет 770 недоступен (EACCES).
  Least-privilege: только членство в группе, не права владельца. Допущение: группа
  redis уже существует на хосте (её создаёт пакет redis-server).

  systemd-hardening (прод-конвенция §3, «безопасность на первом месте»,
  requirements.md): NoNewPrivileges + ProtectSystem=strict (весь / только-чтение)
  + изоляция home/tmp/ядра/cgroups + RestrictAddressFamilies с AF_UNIX (exporter
  ходит в Redis через unix-сокет — без AF_UNIX connect() упрётся в блокировку
  семейства адресов; прод-конвенция §3 — AF_UNIX только реально использующим сокет
  демонам) + пустой CapabilityBoundingSet. Расширенный блок (MemoryDenyWriteExecute,
  SystemCallFilter=@system-service, RestrictNamespaces, LockPersonality) — как у
  эталонной destiny: exporter — статический Go-бинарь без JIT и работы с namespaces.

  .vars.extra_args — passthrough-канал (прод-конвенция §1) для любых флагов
  redis_exporter сверх --redis.addr/--web.listen-address: дополнительные коллекторы
  (--check-keys=...), TLS/basic-auth (--web.config.file=<path>; сам web.yml —
  отдельный файл, не из этого сценария, §4). range дописывает каждый элемент
  отдельным аргументом ExecStart (не разбивается по пробелам).
*/}}
[Unit]
Description=Prometheus Redis Exporter
Documentation=https://github.com/oliver006/redis_exporter
After=network-online.target redis-server.service
Wants=network-online.target

[Service]
Type=simple
User=redis-exporter
Group=redis-exporter
ExecStart={{ .vars.bin_dir }}/redis_exporter --redis.addr={{ .vars.redis_addr }} --web.listen-address={{ .vars.listen }}{{ range .vars.extra_args }} {{ . }}{{ end }}
Restart=on-failure
RestartSec=5

# systemd-hardening (прод-конвенция §3). AF_UNIX добавлен к AF_INET/AF_INET6 —
# redis_exporter подключается к Redis через unix-сокет (--redis.addr=unix://...).
NoNewPrivileges=yes
ProtectSystem=strict
ProtectHome=yes
PrivateTmp=yes
ProtectKernelTunables=yes
ProtectControlGroups=yes
RestrictAddressFamilies=AF_INET AF_INET6 AF_UNIX
CapabilityBoundingSet=
MemoryDenyWriteExecute=yes
SystemCallFilter=@system-service
RestrictNamespaces=yes
LockPersonality=yes

[Install]
WantedBy=multi-user.target
