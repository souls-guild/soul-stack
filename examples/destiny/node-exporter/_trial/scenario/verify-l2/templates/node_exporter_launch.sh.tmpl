#!/bin/sh
{{/*
  Launch-скрипт mock-листенера node_exporter для L2-харнесса (Trial, Вариант A).
  Контекст рендера (docs/templating.md §3.2): .vars.listen — listen-адрес host:port.
  Движок — Go text/template + sprig-allowlist, strict-mode (ADR-010).

  В ПРОДЕ здесь был бы systemd-unit (см. ../../../templates/node_exporter.service.tmpl),
  запускающий настоящий бинарь node_exporter под системным аккаунтом node_exporter.
  В герметичном L2-пилоте (без сети для fetch бинаря и без systemd-PID1) листенер —
  минимальный python-HTTP-сервер на том же порту, отдающий node_exporter-подобный
  /metrics. Демонстрирует, что core.file.rendered доставил рабочий исполняемый
  артефакт на реальный Linux.
*/}}
# listen-адрес зашит рендером из .vars.listen (CEL-rendered Keeper-side).
LISTEN='{{ .vars.listen }}'
PORT="${LISTEN##*:}"

exec python3 - "$PORT" <<'PYEOF'
import sys
from http.server import BaseHTTPRequestHandler, HTTPServer

PORT = int(sys.argv[1])
BODY = b"# HELP node_exporter_build_info node_exporter mock build info\nnode_exporter_build_info{version=\"mock\"} 1\n"

class H(BaseHTTPRequestHandler):
    def do_GET(self):
        self.send_response(200)
        self.send_header("Content-Type", "text/plain")
        self.end_headers()
        self.wfile.write(BODY)
    def log_message(self, *a):
        pass

HTTPServer(("127.0.0.1", PORT), H).serve_forever()
PYEOF
