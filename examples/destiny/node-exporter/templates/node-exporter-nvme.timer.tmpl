{{/*
  Таймер NVMe-сборщика. Контекст рендера пуст (vars: {}) — шаблон статичен,
  .tmpl обязателен для core.file.rendered. Движок — Go text/template strict
  (ADR-010).

  Та же ConditionPathExistsGlob=/dev/nvme[0-9]* в [Unit], что и в .service:
  защита от ручного start без NVMe-устройства.
*/}}
[Unit]
Description=Run NVMe metrics collection every 1 minute
ConditionPathExistsGlob=/dev/nvme[0-9]*

[Timer]
OnBootSec=0
OnUnitActiveSec=1min

[Install]
WantedBy=timers.target
