{{/*
  systemd drop-in hardening для redis-server (ADR-010). Контекст: .vars.data_dir/
  run_dir/log_dir/conf_dir. Набор УНИФИЦИРОВАН с redis-sentinel.service.tmpl (NIM-97);
  guard — TestRedisServerHardening_CanonDirectives.

  Drop-in (не свой unit): distro-юнит redis-server.service заменять нельзя (несёт
  ExecStart/Type=notify, обновляется с пакетом) → hardening доезжает override-ом в
  .service.d/. User/Group НЕ задаём (stateful redis требует стабильного uid data-dir;
  аккаунт redis:redis заводит пакет).

  conf_dir в ReadWritePaths ОБЯЗАТЕЛЕН: update_config → CONFIG REWRITE переписывает
  redis.conf; без conf_dir ProtectSystem=strict держит /etc R/O → REWRITE падает.
  MemoryDenyWriteExecute=yes — эталон redis.io-deb 8.8.0-1rl1; модули (bloom/json/
  search/timeseries) — AOT-.so через dlopen (R+X, не W+X), jemalloc/Lua тоже без W+X,
  JIT у Redis нет → не ломает (live-verified NIM-97).
  UMask=007 — RDB/AOF/лог 0660 (данные от others закрыты). CapabilityBoundingSet= пуст —
  строже эталона redis.io-deb (тот держит CAP_SYS_RESOURCE); rlimit покрыт статическим
  LimitNOFILE=65535 (redis сам rlimit не поднимет без CAP_SYS_RESOURCE). AF_UNIX в
  RestrictAddressFamilies — redis unix-сокет + sd_notify Type=notify.
*/}}
[Service]
NoNewPrivileges=yes
ProtectSystem=strict
ReadWritePaths={{ .vars.data_dir }} {{ .vars.run_dir }} {{ .vars.log_dir }} {{ .vars.conf_dir }}
ProtectHome=yes
PrivateTmp=yes
PrivateDevices=yes
ProtectKernelTunables=yes
ProtectKernelModules=yes
ProtectControlGroups=yes
RestrictAddressFamilies=AF_INET AF_INET6 AF_UNIX
RestrictNamespaces=yes
RestrictRealtime=yes
RestrictSUIDSGID=yes
LockPersonality=yes
MemoryDenyWriteExecute=yes
UMask=007
CapabilityBoundingSet=
LimitNOFILE=65535
