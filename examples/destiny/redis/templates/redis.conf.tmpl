{{/*
  redis.conf для режим-агностичного standalone-кирпича Redis (Go text/template strict,
  ADR-010). Контекст: .vars (password, config + host-layout), .self (primary_ip для bind).

  Bind на primary_ip + 127.0.0.1: внешние клиенты — по IP хоста, локальные — по
  loopback.

  ВАЖНО: этот файл ЦЕЛИКОМ заменяет дистрибутивный /etc/redis/redis.conf,
  поэтому он обязан САМ задавать все критичные для systemd-managed Redis директивы —
  иначе вступают встроенные дефолты бинаря redis-server, а не дистрибутивные.
  Конкретно:
    - `dir {{ "{{" }} .vars.data_dir {{ "}}" }}` — рабочий каталог под RDB/AOF, выводится из
      data_dir (директива B: data-dir переопределяем оператором, дефолт /var/lib/redis).
      Встроенный дефолт `dir /` read-only для пользователя redis; при SIGTERM-рестарте
      Redis пишет финальный RDB-снапшот, падает «Read-only file system» и НЕ выходит →
      рестарт висит вечно. КРИТИЧНО: при override data_dir RDB/AOF обязаны писаться в
      ФАКТИЧЕСКИЙ каталог данных, иначе тот же read-only-инцидент на чужом пути.
      Каталог создаёт пакет redis (owner redis:redis, mode 0750).
    - `aclfile {{ "{{" }} .vars.conf_dir {{ "}}" }}/users.acl` — внешний ACL-файл, выводится из
      conf_dir (директива B: conf-dir переопределяем, дефолт /etc/redis). destiny кладёт
      users.acl в ${conf_dir}/users.acl (server.yml) — redis.conf обязан смотреть ТУДА ЖЕ,
      иначе при override conf_dir aclfile разъезжается с реальным путём.
    - daemonize/supervised/pidfile/logfile — под управление systemd-юнитом
      redis-server (Type=notify, supervised systemd). pidfile/logfile — СИСТЕМНЫЕ
      run-/log-каталоги (.vars.run_dir/.vars.log_dir, дефолт /var/run/redis,
      /var/log/redis); каталоги вынесены в vars (vars.run_dir/vars.log_dir), basename
      файла (redis-server.pid/.log) — имя демона, литерал.
    - `port {{ "{{" }} .vars.port {{ "}}" }}` — well-known порт redis-server
      (vars.redis_port, дефолт 6379). merged .vars.config ниже может переопределить
      last-wins (напр. `port 0` при tls.only).

  Persistence (save/appendonly) НЕ зашита здесь: она приходит в .vars.config от
  persistence-пресета scenario (essence.persistence_presets[input.persistence]) и
  range-ится ниже вместе с остальным merged-конфигом.

  .vars.config — merged-конфиг от scenario сервиса (default→preset→вычисления→
  passthrough, слит через merge() в render-фазе). Идёт ПОСЛЕ базовых директив,
  поэтому caller может осознанно переопределить любую (last-wins в redis.conf).
  Пусто → секция пуста. unixsocket/unixsocketperm/maxmemory/maxmemory-policy/save/
  appendonly — обычные ключи этого map-а (их вычислил scenario).

  cluster-announce-ip — ПЕР-ХОСТ-директива (режим cluster): IP, который ЭТА нода
  анонсирует в gossip cluster-bus. Берётся из .self.network.primary_ip (адрес
  ИМЕННО этого хоста, render_context.self пер-хост — симметрично bind), а НЕ из
  .vars.config: apply.input резолвится host-ИНВАРИАНТНО (на первом по SID хосте),
  поэтому протаскивать announce-ip через config-map нельзя — все ноды получили бы
  IP первой ноды и cluster-bus за NAT/в облаке сломался бы. Остальные
  cluster-директивы (cluster-enabled/cluster-config-file/cluster-node-timeout)
  host-инвариантны → приходят обычными ключами .vars.config. Гейт по
  `cluster-enabled` в config: вне cluster-режима строки announce-ip нет.
*/}}
bind {{ .self.network.primary_ip }} 127.0.0.1
port {{ .vars.port }}
protected-mode yes

# Управление через systemd-юнит redis-server (пакет дистрибутива).
# daemonize no + supervised systemd: redis-server остаётся foreground-процессом и
# сам уведомляет systemd о готовности (Type=notify в юните).
daemonize no
supervised systemd
pidfile {{ .vars.run_dir }}/redis-server.pid
logfile {{ .vars.log_dir }}/redis-server.log

# Рабочий каталог под RDB/AOF (КРИТИЧНО, см. шапку: без него дамп в read-only `/` →
# зависание рестарта).
dir {{ .vars.data_dir }}

requirepass {{ .vars.password }}

# ACL-юзеры в отдельном файле (см. шапку про aclfile/conf_dir).
aclfile {{ .vars.conf_dir }}/users.acl

{{- if (index .vars.config "cluster-enabled") }}
# Режим cluster: эта нода анонсирует СВОЙ primary_ip в gossip (per-host, см. шапку).
cluster-announce-ip {{ .self.network.primary_ip }}
{{- end }}

{{/*
  Redis-модули (Redis < 8): директивы loadmodule идут ОТДЕЛЬНОЙ секцией, а НЕ ключами
  .vars.config — у loadmodule нет значения, а range config-а печатает `{{key}} {{value}}`
  (с пустым value → хвостовой пробел). .vars.loadmodules — готовый список путей .so,
  вычислен в server.yml (тернар по vars.redis_is_v8plus; на Redis 8+ пуст — встроены).
  `index .vars "loadmodules"` (built-in, как cluster-enabled выше): на отсутствующем
  ключе возвращает nil без ошибки в strict-mode (в отличие от `.vars.loadmodules`).
*/}}
{{- range (index .vars "loadmodules") }}
loadmodule {{ . }}
{{- end }}

{{ range $key, $value := .vars.config }}
{{ $key }} {{ $value }}
{{- end }}
