{{/*
  logrotate config for Redis log files (/etc/logrotate.d/redis). Go text/template strict
  (ADR-010). .vars.log_dir -- redis's system log directory.

  The glob {{ .vars.log_dir }}/*.log matches the logfile setting in redis.conf.tmpl and sentinel.conf.tmpl
  (both daemons write to the same log_dir, so the glob covers both).

  copytruncate: Redis держит лог-файл открытым и не умеет реагировать на сигнал
  пере-открытия лога, поэтому ротация копированием+усечением (а не rename+создание)
  — единственный безопасный вариант без рестарта/HUP сервиса. rename+create
  (deb-вариант redis.io) для Redis ХРУПОК — тот же fd, новый лог пуст до рестарта;
  copytruncate закреплён как проверенный (NIM-97, guard —
  TestRedisLogrotate_Copytruncate). daily + rotate 7:
  суточная ротация, хранение недели. compress + delaycompress: сжатие со сдвигом на
  одну ротацию (свежий .1 остаётся несжатым для оперативного просмотра). missingok +
  notifempty: лог может отсутствовать (сервис не стартовал) или быть пустым —
  не ошибка.
*/}}
{{ .vars.log_dir }}/*.log {
  daily
  rotate 7
  size 512M
  copytruncate
  compress
  delaycompress
  missingok
  notifempty
}
