{{/*
  logrotate config for Redis log files (/etc/logrotate.d/redis). Go text/template strict
  (ADR-010). .vars.log_dir -- redis's system log directory.

  The glob {{ .vars.log_dir }}/*.log matches the logfile setting in redis.conf.tmpl and sentinel.conf.tmpl
  (both daemons write to the same log_dir, so the glob covers both).

  copytruncate: Redis keeps the log file open and can't react to a log-reopen
  signal, so rotation via copy+truncate (rather than rename+create)
  is the only safe option without a service restart/HUP. daily + rotate 7:
  daily rotation, one week of retention. compress + delaycompress: compression offset by
  one rotation (the fresh .1 stays uncompressed for quick review). missingok +
  notifempty: the log may be absent (service hasn't started) or empty --
  not an error.
*/}}
{{ .vars.log_dir }}/*.log {
  daily
  rotate 7
  size 512M
  copytruncate
  compress
  delaycompress
  missingok
  notifempty
}
