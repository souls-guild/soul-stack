{{/*
  Drop-in /etc/sysctl.d/30-redis.conf — kernel-параметры под Redis. Образец —
  sysctl-блок Ansible tasks/installation.yml роли redis (БЕЗ tcp_bbr/modprobe:
  bbr отложен — нет core.modprobe, ADR-015 amend требуется отдельно). Контекст
  рендера (docs/templating.md §3.2):
    .vars.sysctl_settings — отсортированный map kernel-параметр→значение (scenario
      сервиса передаёт его через apply.input; дефолты — essence.sysctl_settings).
    .self  — стабильные факты хоста (здесь не используются).
  Движок — Go text/template + sprig-allowlist, strict-mode (ADR-010).

  range по MAP сортирует ключи → строки drop-in детерминированы между прогонами →
  нет ложного change/повторного `sysctl --system`. Значения map-а — строки
  (range-ятся как `<key> = <value>`): multi-value параметры (tcp_rmem/ip_local_
  port_range) задаются строкой с пробелами.

  Drop-in В ОТДЕЛЬНОМ файле /etc/sysctl.d/30-redis.conf (не общий sysctl.conf):
  изоляция параметров роли + персистентность после reboot. Применяется задачей
  destiny через `sysctl --system` (onchanges на этот файл).
*/}}
# kernel-параметры под Redis (drop-in роли). Применяется `sysctl --system`.
{{- range $key, $value := .vars.sysctl_settings }}
{{ $key }} = {{ $value }}
{{- end }}
