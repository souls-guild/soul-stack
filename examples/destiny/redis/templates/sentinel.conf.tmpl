{{/*
  sentinel.conf для redis-sentinel-демона (режим sentinel). Go text/template strict
  (ADR-010). Контекст: .vars (sentinel_config, monitor, auth, каталоги/порт), .self
  (primary_ip для announce-ip).

  ПЕР-ХОСТ vs HOST-ИНВАРИАНТ (TILING-урок qa 2026-06-22):
    - sentinel announce-ip — ПЕР-ХОСТ (IP ИМЕННО этого sentinel-а в gossip), берётся
      из .self.network.primary_ip, НЕ из apply.input (тот резолвится host-инвариантно на
      первом по SID хосте → все sentinel-ы получили бы один IP → анонс сломан за NAT).
    - sentinel monitor <master>: адрес HOST-ИНВАРИАНТНЫЙ (ОДИН master), приходит .vars.

  .vars.sentinel_config — отсортированный map стартовых директив (range по MAP сортирует
  ключи → нет ложного change). monitor/auth — ОТДЕЛЬНЫМИ строками ниже (нужны master + quorum).
*/}}
port {{ .vars.port }}

# Под управление systemd-юнитом redis-sentinel (Type=notify, supervised systemd).
daemonize no
supervised systemd
pidfile {{ .vars.run_dir }}/redis-sentinel.pid
logfile {{ .vars.log_dir }}/redis-sentinel.log
# Рабочий каталог: sentinel пишет сюда свой state.
dir {{ .vars.data_dir }}

# ВТОРОЙ aclfile — ТОЛЬКО для sentinel-демона (отдельный набор от users.acl redis-server).
# Пустой файл валиден (back-compat).
aclfile {{ .vars.conf_dir }}/sentinel-users.acl

# Стартовые директивы из переданного map (отсортированы range-ом по ключам).
{{- range $key, $value := .vars.sentinel_config }}
{{ $key }} {{ $value }}
{{- end }}

# ПЕР-ХОСТ: этот sentinel анонсирует СВОЙ primary_ip в gossip (симметрично bind redis.conf).
sentinel announce-ip {{ .self.network.primary_ip }}

# Monitored master (HOST-ИНВАРИАНТНЫЙ адрес: один master на кластер).
# auth-user/auth-pass — для AUTH sentinel-а на master. ★ РЕДИЗАЙН default_admin (2026-06-30):
# requirepass убран, master защищён ACL → sentinel ОБЯЗАН ходить под ACL-юзером. Деплой-тело
# передаёт auth_user = default_admin (compute.admin_user) + auth_pass — пароль default_admin.
# Без auth_user sentinel пошёл бы под built-in default (теперь off в users.acl) → NOAUTH.
sentinel monitor {{ .vars.master_name }} {{ .vars.master_ip }} {{ .vars.master_port }} {{ .vars.quorum }}
{{- if .vars.auth_user }}
sentinel auth-user {{ .vars.master_name }} {{ .vars.auth_user }}
{{- end }}
{{- if .vars.auth_pass }}
sentinel auth-pass {{ .vars.master_name }} {{ .vars.auth_pass }}
{{- end }}
