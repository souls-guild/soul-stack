{{/*
  systemd unit redis_exporter. Render context (docs/templating.md §3.2):
    .vars  - explicitly passed by core.file.rendered (bin_dir, listen, redis_addr,
             password, extra_args);
    .self  - stable host facts (unused here).
  Engine - Go text/template + sprig-allowlist, strict-mode (ADR-010).

  Connection to Redis - via UNIX SOCKET: --redis.addr=unix:///<path>
  (.vars.redis_addr already carries the unix:// prefix, built in tasks/main.yml from
   input.redis_socket - the same path as unixsocket in redis.conf of destiny redis-single).

  Service account - DynamicUser=yes (prod convention §2, hybrid rule): systemd itself
  spins up a locked-down transient user for the process lifetime. redis_exporter is a
  stateless daemon without an owned data-dir, doesn't need a stable uid, manual
  core.user/core.group are NOT created. Doesn't work as root.

  Group access to the Redis unix socket (unixsocketperm 770, owner redis:redis): the socket
  admits the "group" (rwx), so the transient user needs membership in the redis group.
  It's granted via SupplementaryGroups=redis - this is compatible with DynamicUser:
  systemd adds the ephemeral uid to an existing statically-named group for the process
  lifetime (the redis group is created as a side effect of the redis-server package - postinst
  in the core.pkg.installed step of destiny redis-single, applied earlier - not an explicit
  core.group step). redis exporter does NOT get owner rights, only group membership.

  The Redis password is passed via Environment=REDIS_PASSWORD (redis_exporter reads
  it from env), not in ExecStart - to avoid leaking it in `ps`/journalctl. The ACL username
  (.vars.redis_user) - in ExecStart as the --redis.user flag (not a secret): empty -> flag omitted
  (requirepass model, default-user), set -> AUTH as that user (needed on an ACL instance
  without requirepass, otherwise WRONGPASS). The unit file
  is written with mode 0644; on a host where that matters, restrict access to the
  /etc/systemd/system directory or use a drop-in with EnvironmentFile mode 0600.

  systemd hardening (prod convention §3, "security first",
  requirements.md): NoNewPrivileges + ProtectSystem=strict (whole tree / read-only)
  + isolation of home/tmp/kernel/cgroups + RestrictAddressFamilies. Unlike
  node-exporter, AF_UNIX is MANDATORY in the list here: redis_exporter talks to Redis
  via a unix socket, and without AF_UNIX connect() to the socket would hit EACCES/an
  address-family block (prod convention §3 - AF_UNIX is added only for daemons that
  actually use a unix socket). The extended block (MemoryDenyWriteExecute,
  SystemCallFilter=@system-service, RestrictNamespaces, LockPersonality) complements
  the base one: the exporter is a static Go binary without JIT and without namespace usage.

  .vars.extra_args - a passthrough channel for any redis_exporter flags beyond
  --redis.addr/--web.listen-address: extra collectors (--check-keys=...),
  TLS/basic-auth (--web.config.file=<path>; web.yml itself is a separate file, not part
  of this destiny). range appends each element as a separate ExecStart argument.
*/}}
[Unit]
Description=Prometheus Redis Exporter
Documentation=https://github.com/oliver006/redis_exporter
After=network-online.target redis-server.service
Wants=network-online.target
Requires=redis-server.service

[Service]
Type=simple
DynamicUser=yes
# group access to the Redis unix socket (770) for the transient DynamicUser.
SupplementaryGroups=redis
Environment=REDIS_PASSWORD={{ .vars.password }}
ExecStart={{ .vars.bin_dir }}/redis_exporter --redis.addr={{ .vars.redis_addr }} --web.listen-address={{ .vars.listen }}{{ if .vars.redis_user }} --redis.user={{ .vars.redis_user }}{{ end }}{{ range .vars.extra_args }} {{ . }}{{ end }}
Restart=on-failure
RestartSec=5

# systemd hardening (prod convention §3). AF_UNIX added to AF_INET/AF_INET6 -
# redis_exporter connects to Redis via a unix socket (--redis.addr=unix://...).
NoNewPrivileges=yes
ProtectSystem=strict
ProtectHome=yes
PrivateTmp=yes
ProtectKernelTunables=yes
ProtectControlGroups=yes
RestrictAddressFamilies=AF_INET AF_INET6 AF_UNIX
CapabilityBoundingSet=
MemoryDenyWriteExecute=yes
SystemCallFilter=@system-service
RestrictNamespaces=yes
LockPersonality=yes

[Install]
WantedBy=multi-user.target
