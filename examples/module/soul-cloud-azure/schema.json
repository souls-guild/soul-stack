{
  "type": "object",
  "required": ["location", "vm_size", "image", "subnet_id"],
  "properties": {
    "location": {
      "type": "string",
      "examples": ["westeurope", "eastus", "northeurope"]
    },
    "vm_size": {
      "type": "string",
      "examples": ["Standard_B2s", "Standard_D2s_v5"]
    },
    "image": {
      "type": "object",
      "required": ["publisher", "offer", "sku"],
      "properties": {
        "publisher": { "type": "string" },
        "offer":     { "type": "string" },
        "sku":       { "type": "string" },
        "version":   { "type": "string", "default": "latest" }
      }
    },
    "subnet_id": {
      "type": "string",
      "pattern": "^/subscriptions/[^/]+/resourceGroups/[^/]+/providers/Microsoft\\.Network/virtualNetworks/[^/]+/subnets/[^/]+$"
    },
    "admin_username": { "type": "string", "default": "soul" },
    "ssh_public_key": { "type": "string" },
    "public_ip": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "sku":     { "type": "string", "enum": ["Basic", "Standard"], "default": "Standard" },
        "dns_label": { "type": "string" }
      }
    },
    "disk": {
      "type": "object",
      "properties": {
        "size_gb": { "type": "integer", "minimum": 30 },
        "type":    { "type": "string", "enum": ["Standard_LRS", "StandardSSD_LRS", "Premium_LRS"] }
      }
    },
    "network_security_group_id": { "type": "string" },
    "tags": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  }
}
