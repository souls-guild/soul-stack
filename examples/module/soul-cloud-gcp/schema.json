{
  "type": "object",
  "required": ["project", "zone", "machine_type", "source_image"],
  "properties": {
    "project": {
      "type": "string",
      "pattern": "^[a-z][-a-z0-9]{4,28}[a-z0-9]$"
    },
    "zone": {
      "type": "string",
      "pattern": "^[a-z]+-[a-z]+[0-9]+-[a-z]$"
    },
    "machine_type": {
      "type": "string",
      "examples": ["e2-medium", "n2-standard-2", "c2-standard-4"]
    },
    "source_image": {
      "type": "string",
      "pattern": "^(projects/[a-z][-a-z0-9]+/global/images/(family/)?[a-z][-a-z0-9.]+|https://www\\.googleapis\\.com/compute/v1/.+)$"
    },
    "disk": {
      "type": "object",
      "properties": {
        "size_gb": { "type": "integer", "minimum": 10 },
        "type": { "type": "string", "enum": ["pd-standard", "pd-balanced", "pd-ssd", "hyperdisk-balanced"] }
      }
    },
    "network": {
      "type": "object",
      "properties": {
        "network": { "type": "string" },
        "subnet": { "type": "string" }
      }
    },
    "labels": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  }
}
