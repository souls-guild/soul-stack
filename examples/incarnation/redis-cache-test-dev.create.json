{
  "_comment": "POST /v1/incarnation/create — создание нового Redis-кластера через cloud-spawn",

  "name": "test-cache-redis-cl-dev",
  "service": "redis-cluster",
  "service_version": ">= 1.4",
  "scenario": "create",

  "inputs": {
    "redis_version": "7.2.4",
    "redis_password": "vault:secret/redis/test-cache-dev/password",
    "redis_users": {
      "app": {
        "acl": "on ~cache:* +@read +@write -@dangerous",
        "state": "on"
      },
      "monitor": {
        "acl": "on ~* +ping +info +client",
        "state": "on"
      }
    },
    "redis_config": {
      "maxmemory": "2gb",
      "maxmemory-policy": "allkeys-lru"
    },
    "spawn": {
      "provider": "aws-prod",
      "profile": "redis-medium-eu",
      "count": 3,
      "role_distribution": [
        { "index": "0",   "role": "primary" },
        { "index": "1-2", "role": "replica" }
      ]
    }
  }
}
