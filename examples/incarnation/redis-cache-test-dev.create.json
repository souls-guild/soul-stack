{
  "_comment": "POST /v1/incarnation/create — создание Redis Cluster (консолидированный service redis, redis_type=cluster)",

  "name": "test-cache-redis-cl-dev",
  "service": "redis",
  "service_version": "v1.0.0",
  "scenario": "create",

  "inputs": {
    "redis_type": "cluster",
    "version": "5:7.0.15-1~deb12u7",
    "memory_mb": 2048,
    "maxmemory_policy": "allkeys-lru",
    "shards": 3,
    "replicas_per_shard": 1,
    "users": {
      "app": {
        "perms": "on ~cache:* +@read +@write -@dangerous",
        "state": "on"
      },
      "monitor": {
        "perms": "on ~* +ping +info +client",
        "state": "on"
      }
    }
  }
}
