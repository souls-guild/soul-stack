# PM workspace
.pm/

# Serena LSP project config (tool-specific, local)
.serena/

# Nimbalyst GUI local data (tool-specific, local)
nimbalyst-local/

# Claude Code runtime artifacts (scheduled task lockfile)
.claude/scheduled_tasks.lock
.claude/worktrees/

# Go build artefacts
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
*.prof
coverage.txt
coverage.html

# Directory of built binaries inside each module with `main` (see Makefile, BIN_DIR).
*/bin/

# Directory of temporary binaries soul-trial / soul-lint (keeper/.bin, soul-lint/.bin) -
# `*/bin/` doesn't cover it (.bin != bin).
*/.bin/

# Directory of release artifacts (SBOM, deb/rpm) - see Makefile, DIST_DIR (make sbom/pkg).
dist/

# Defensive: stray binaries in module roots with main (if someone runs `go build .` outside the Makefile).
/keeper/keeper
/soul/soul
/soul-lint/soul-lint
/soulctl/soulctl

# Defensive: stray plugin binaries from `go build .` in an example-module root (convention - dist/<binary>).
/examples/module/soul-cloud-aws/soul-cloud-aws
/examples/module/soul-cloud-proxmox/soul-cloud-proxmox
/examples/module/soul-ssh-static/soul-ssh-static

# Vendor / dependency directories are not used in this repo
vendor/

# Python bytecode cache (from scripts/check-doc-links.py)
__pycache__/

# Editor / IDE
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# compiled example plugin binaries (ADR-011: examples = non-Go only).
# Convention: the binary sits at examples/module/<plugin>/<plugin> (name == directory).
# The pattern `*/soul-...-*` requires exactly one directory level BEFORE the binary name ->
# it matches the binary itself inside the plugin directory, but NOT the whole plugin directory
# (otherwise `**` would hide the plugin SOURCES - main.go/impl.go/manifest.yaml).
examples/module/*/soul-cloud-*
examples/module/*/soul-ssh-*
examples/module/*/soul-mod-*
