#cloud-config
{{- if .SelfOnboard }}
# Soul Stack — cloud-init userdata (ADR-017(h) amendment, self-onboard «Вариант T»).
# ★ Per-VM bootstrap-токены ЗАПЕЧЕНЫ в userdata (map FQDN->token ниже): VM выбирает
# свой токен по hostname и онбордится (soul init) в один цикл cloud-init, без
# claim-callback и без keeper.push. ТЕСТ-СТЕНД: userdata хранится провайдером в
# plaintext metadata — осознанный компромисс. TODO(prod): late-binding claim.
{{- else }}
# Soul Stack — cloud-init userdata (ADR-017(h) amendment 2026-05-27, B-flat).
# Per-VM bootstrap-токен НЕ хранится здесь — он доставляется отдельным шагом
# scenario (типично keeper.push через SSH-провайдер). См. docs/keeper/cloud.md.
{{- end }}
{{- if .SoulVersion }}
# soul-version: {{ .SoulVersion }}
{{- end }}

write_files:
  - path: /etc/soul/tls/keeper-ca.pem
    owner: root:root
    permissions: '0644'
    content: |
{{ .TLSCAPemIndented }}
  - path: /etc/soul/soul.yml
    owner: root:root
    permissions: '0644'
    content: |
{{ .SoulConfigYAMLIndented }}
  - path: /etc/systemd/system/soul.service
    owner: root:root
    permissions: '0644'
    content: |
{{ .SystemdUnitIndented }}
{{- if .SelfOnboard }}
  # Map FQDN->bootstrap-token (self-onboard). Формат `<fqdn> <token>` построчно;
  # soul init ниже выбирает свою строку по $(hostname -f). Права 0600 (секреты).
  - path: /etc/soul/self-onboard-tokens
    owner: root:root
    permissions: '0600'
    content: |
{{ .SelfOnboardTokensIndented }}
{{- end }}

runcmd:
  - install -d -m 0755 /etc/soul /var/lib/soul-stack /var/lib/soul-stack/modules /var/lib/soul-stack/seed
{{- if .UseSystemCA }}
  # soul_binary_ca=system: curl верит системному trust-store (для artifact-хостов
  # с публичным CA, напр. Nexus за GlobalSign). Ослабляет ТОЛЬКО верификацию cert
  # artifact-хоста — keeper-CA-pin Bootstrap-канала и SHA256-verify бинаря не затронуты.
  - curl --fail --show-error --silent --output /usr/local/bin/soul {{ .SoulBinaryURL }}
{{- else }}
  # soul_binary_ca=keeper (default): curl пинится на keeper-CA при скачивании бинаря.
  - curl --fail --show-error --silent --cacert /etc/soul/tls/keeper-ca.pem --output /usr/local/bin/soul {{ .SoulBinaryURL }}
{{- end }}
  - chmod 0755 /usr/local/bin/soul
{{- if .SelfOnboard }}
  # self-onboard: выбираем свой токен по hostname (не хардкод) и делаем bootstrap
  # (soul init) ДО запуска демона. ★ Токен идёт через env SOUL_BOOTSTRAP_TOKEN,
  # НЕ через argv --token= — argv виден в ps/journald на самой VM. init одноразов
  # (генерит key+CSR -> Bootstrap-RPC -> SoulSeed); после него soul.service поднимает
  # уже онбордившийся демон. Неуспех init -> soul.service всё равно стартует и будет
  # ретраить, но без seed присоединения не будет (диагностика в journald).
  - SOUL_BOOTSTRAP_TOKEN="$(awk -v h="$(hostname -f)" '$1==h {print $2}' /etc/soul/self-onboard-tokens)" /usr/local/bin/soul init --config /etc/soul/soul.yml
{{- end }}
  - systemctl daemon-reload
  - systemctl enable soul.service
  - systemctl start soul.service
