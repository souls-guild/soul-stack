#cloud-config
# Soul Stack — cloud-init userdata (ADR-017(h) amendment 2026-05-27, B-flat).
# Per-VM bootstrap-токен НЕ хранится здесь — он доставляется отдельным шагом
# scenario (типично keeper.push через SSH-провайдер). См. docs/keeper/cloud.md.
{{- if .SoulVersion }}
# soul-version: {{ .SoulVersion }}
{{- end }}

write_files:
  - path: /etc/soul/tls/keeper-ca.pem
    owner: root:root
    permissions: '0644'
    content: |
{{ .TLSCAPemIndented }}
  - path: /etc/soul/soul.yml
    owner: root:root
    permissions: '0644'
    content: |
{{ .SoulConfigYAMLIndented }}
  - path: /etc/systemd/system/soul.service
    owner: root:root
    permissions: '0644'
    content: |
{{ .SystemdUnitIndented }}

runcmd:
  - install -d -m 0755 /etc/soul /var/lib/soul-stack /var/lib/soul-stack/modules /var/lib/soul-stack/seed
{{- if .UseSystemCA }}
  # soul_binary_ca=system: curl верит системному trust-store (для artifact-хостов
  # с публичным CA, напр. Nexus за GlobalSign). Ослабляет ТОЛЬКО верификацию cert
  # artifact-хоста — keeper-CA-pin Bootstrap-канала и SHA256-verify бинаря не затронуты.
  - curl --fail --show-error --silent --output /usr/local/bin/soul {{ .SoulBinaryURL }}
{{- else }}
  # soul_binary_ca=keeper (default): curl пинится на keeper-CA при скачивании бинаря.
  - curl --fail --show-error --silent --cacert /etc/soul/tls/keeper-ca.pem --output /usr/local/bin/soul {{ .SoulBinaryURL }}
{{- end }}
  - chmod 0755 /usr/local/bin/soul
  - systemctl daemon-reload
  - systemctl enable soul.service
  - systemctl start soul.service
