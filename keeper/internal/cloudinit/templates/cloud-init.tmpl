#cloud-config
# Soul Stack — cloud-init userdata (ADR-017(h) amendment 2026-05-27, B-flat).
# Per-VM bootstrap-токен НЕ хранится здесь — он доставляется отдельным шагом
# scenario (типично keeper.push через SSH-провайдер). См. docs/keeper/cloud.md.
{{- if .SoulVersion }}
# soul-version: {{ .SoulVersion }}
{{- end }}

write_files:
  - path: /etc/soul/tls/keeper-ca.pem
    owner: root:root
    permissions: '0644'
    content: |
{{ .TLSCAPemIndented }}
  - path: /etc/soul/soul.yml
    owner: root:root
    permissions: '0644'
    content: |
      # Минимальный конфиг soul-агента для cloud-init bootstrap.
      # Per-VM-токен и SoulSeed-сертификат добавит следующий шаг scenario.
      paths:
        modules: /var/lib/soul-stack/modules
        seed:    /var/lib/soul-stack/seed
      keeper:
        endpoints:
          - host: {{ .BootstrapHost }}
            event_stream_port: {{ .BootstrapPort }}
            bootstrap_port: {{ .BootstrapPort }}
        tls:
          ca: /etc/soul/tls/keeper-ca.pem
  - path: /etc/systemd/system/soul.service
    owner: root:root
    permissions: '0644'
    content: |
      [Unit]
      Description=Soul Stack agent
      After=network-online.target
      Wants=network-online.target

      [Service]
      Type=simple
      ExecStart=/usr/local/bin/soul run --config /etc/soul/soul.yml
      Restart=on-failure
      RestartSec=5s

      [Install]
      WantedBy=multi-user.target

runcmd:
  - install -d -m 0755 /etc/soul /var/lib/soul-stack /var/lib/soul-stack/modules /var/lib/soul-stack/seed
  - curl --fail --show-error --silent --cacert /etc/soul/tls/keeper-ca.pem --output /usr/local/bin/soul {{ .SoulBinaryURL }}
  - chmod 0755 /usr/local/bin/soul
  - systemctl daemon-reload
  - systemctl enable soul.service
  - systemctl start soul.service
