package main

import (
	"log"
	"os"

	"{{.GoModulePath}}/internal/{{.NamePackage}}"
	"github.com/souls-guild/soul-stack/sdk/module"
)

func main() {
	impl := &{{.NamePackage}}.{{.NamePascal}}Module{}
	if err := module.Serve(impl); err != nil {
		log.Printf("{{.BinaryName}}: %v", err)
		os.Exit(1)
	}
}
