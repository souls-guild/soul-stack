kid: ${KID}

listen:
  # bootstrap/event_stream на 0.0.0.0 — доступ docker/remote-душ (host-gateway/host-IP;
  # на 127.0.0.1 контейнер keeper не видит). host-флот цел (0.0.0.0 ⊇ loopback), cert SAN
  # покрывает localhost/127/host.docker.internal/host-IP. NIM-26, прецедент e2e-live config_builder.go.
  grpc:
    bootstrap:
      addr: "0.0.0.0:${BOOTSTRAP_PORT}"
      tls:
        cert: ${STAND_DEV_DIR}/tls/keeper.crt
        key:  ${STAND_DEV_DIR}/tls/keeper.key
    event_stream:
      addr: "0.0.0.0:${ES_PORT}"
      tls:
        cert: ${STAND_DEV_DIR}/tls/keeper.crt
        key:  ${STAND_DEV_DIR}/tls/keeper.key
        # ClientCAs для mTLS: Vault PKI root (CN=soul-stack) — тот же корень,
        # что подписывает SoulSeed-сертификаты. См. dev/provision.sh шаг 7.
        ca:   ${STAND_DEV_DIR}/tls/vault-ca.crt
  openapi: { addr: "127.0.0.1:${OPENAPI_PORT}" }
  mcp:     { addr: "127.0.0.1:${MCP_PORT}" }
  metrics: { addr: "127.0.0.1:${METRICS_PORT}" }

postgres:
  dsn_ref: ${PG_DSN_REF}
  pool: { min: 2, max: 10 }

redis:
  addr: "${REDIS_ADDR}"
  password_ref: ""

vault:
  addr: "${VAULT_ADDR}"
  token: "root"
  auth:
    method: token
  pki_mount: "pki"
  pki_role: "soul-seed"

auth:
  jwt:
    signing_key_ref: ${JWT_KEY_REF}
    issuer: ${ISSUER}
    ttl_default: 24h
    ttl_bootstrap: 720h

otel:
  # Трейсы уходят в dev-стек: otel-collector (docker-compose) на :4317 →
  # Jaeger UI http://127.0.0.1:16686. Insecure-gRPC (dev-collector без TLS).
  enabled: true
  exporter: otlp
  endpoint: "${OTEL_ENDPOINT}"

logging:
  level: info
  format: text
  rotation: { max_size_mb: 100, max_files: 5, compress: false }

# Реестр Service-ов и скаляр default_destiny_source перенесены в Postgres
# (service_registry + keeper_settings, ADR-029). Эти ключи (`services:` /
# `default_destiny_source:` / `default_module_source:`) в keeper.yml больше не
# принимаются — резолв (serviceregistry.Holder) читает только БД. Для dev/E2E
# реестр сеет шаг 10 в dev/provision.sh (прямой psql INSERT, идемпотентный;
# вне dev — управление через `service.*` API, см. keeper/operator-api.md):
#   - keeper_settings[default_destiny_source] = file:///tmp/keeper-dev/destiny/{name}
#   - service hello-world → file:///tmp/keeper-dev/repos/hello-world @ main
#   - service redis       → file:///tmp/keeper-dev/repos/redis @ main
#     (консолидированный redis, ADR-029/redis-консолидация: один режим-агностичный
#      destiny `redis` на все redis_type; резолвится по default_destiny_source:
#      {name} = redis, ref v1.0.0 из redis/service.yml::destiny[]={redis}).
# Seed требует уже применённой схемы (миграции 034/035); на свежей БД он
# отложен до запуска после `keeper init` — повторить `make dev-provision`.

# Sigil — подпись бинарей плагинов + реестр допусков (ADR-026). Без этого блока
# spawn ЛЮБОГО keeper-side плагина (CloudDriver soul-cloud-wb / SshProvider)
# fail-closed (no_trust_anchor). signing_key_ref → Vault KV с ed25519-приватником
# (поле signing_key, PEM PKCS#8). После добавления — рестарт keeper (hot-reload
# Sigil-блок НЕ поднимает) + допуск бинаря через POST /v1/plugins/sigils.
sigil:
  signing_key_ref: ${SIGIL_KEY_REF}

plugins:
  cache_root: ${STAND_DEV_DIR}/plugins
  # work_root — writable корень git-клонов резолвера (ADR-026 F-fetch). Дефолт
  # /var/lib/soul-stack-keeper/plugin-src не писабелен под dev-юзером → clone падал
  # бы, слот оставался пуст. СТРОГО вне cache_root (schema-guard). Каталог создаёт
  # dev/provision.sh.
  work_root: ${STAND_DEV_DIR}/plugin-work
  # CloudDriver-каталог. FilterByCatalog оставляет в discovery только плагины,
  # чьё manifest.name упомянуто здесь (поле `name`); без записи `wb` найденный
  # ручной кеш-слот wb-wb был бы отброшен.
  #
  # DEV-shortcut (без публичного git-репо драйвера): кеш-слот
  # /tmp/keeper-dev/plugins/wb-wb/{manual-0001,current} наполнен ВРУЧНУЮ
  # (manifest.yaml + бинарь soul-cloud-wb из /home/co-cy/vscode/soulstack/wb-plugins).
  # source — file:// без выставленного SOUL_STACK_ALLOW_FILE_REPOS=1: git-резолвер
  # отбракует схему (validateGitScheme → ErrSourceUnavailable), превратит в warning
  # и НЕ тронет ручной current-symlink (per-entry fail-closed в ResolveCatalog).
  # Запись нужна ТОЛЬКО для FilterByCatalog.
  # ВРЕМЕННО, под удаление: с реальным git-репо заменить на
  # { name: wb, source: "ssh://...wb-plugins", ref: "<tag>" }.
  cloud_drivers:
    - { name: wb, source: "file:///dev/null/soul-cloud-wb-manual-slot", ref: "manual-0001" }
  # SoulModule-каталог (эпик core.module.installed, S1). source — git-репо со
  # СОБРАННЫМ бинарём (dist/soul-mod-redis + manifest.yaml), которое материализует
  # dev/provision.sh (шаг 9b). plugingit клонирует его (file://-scheme под
  # SOUL_STACK_ALLOW_FILE_REPOS=1 — keeper-run.sh выставляет), кеширует слот
  # community-redis/<sha> → current: плагин доступен для Sigil-allow (POST
  # /v1/plugins/sigils) и day-2 redis. `name` = manifest.name (redis) для FilterByCatalog.
  soul_modules:
    - { name: redis, source: "file://${STAND_DEV_DIR}/plugin-repos/community-redis", ref: "v1.0.0" }

plugin_runtime:
  socket_dir: ${STAND_DEV_DIR}/plugin-sockets
  startup_timeout: 10s
  shutdown_grace: 10s
  allowed_capabilities:
    - run_as_root
    - network_outbound
    - network_inbound
    - vault_access
    - fs_write_root
    - exec_subprocess
  conflict_policy: warn
  enable_tls: false

hot_reload:
  enable_signal: true
  enable_inotify: false
  audit_correlation_id: true

audit:
  enabled: true
  otel_export: false
  retention_days: 365

# Watchman (изоляция-детект + soul-shedding S2): период probe PG+Redis и порог
# подряд-провалов до принудительного закрытия локальных EventStream-стримов.
# Дефолты (5s / 3) совпадают с config.DefaultWatchman*; вынесены явно для dev-
# наглядности. На локальном single-instance smoke shedding в норме не срабатывает
# (PG/Redis из docker-compose доступны).
watchman_interval: 5s
watchman_fail_threshold: 3

# Refuse-guard soul-shedding (Finding-A, ADR-027(h)): при acolytes=0 + другие
# живые Keeper-инстансы в Conclave Keeper отказывается стартовать. Дефолт false
# (refuse). На single-instance dev-smoke не срабатывает (Conclave.CountLive<=1).
allow_unsafe_single_path_multi_keeper: false

# Acolyte work-queue pool (ADR-027). >0 — keeper полноценный HA-участник:
# apply исполняется через Ward-claim, cross-keeper-dispatch работает. Нужен
# для two-keeper soul-failover демо (см. docs/dev/local-setup.md): keeper-a и
# keeper-b симметричны (оба acolytes>0), refuse-guard не срабатывает ни на
# initial-старте, ни на рестарте keeper-a при живом keeper-b (фаза 4). Значение
# совпадает с keeper-b.dev.yml и стендом мега-теста (3×acolytes:2).
acolytes: 2

# Потолок await_timeout онбординг-барьера (ADR-061): run-бюджет provision = max_await_timeout + 10m deploy → 20m. fail-fast: VM обычно online ~5m, большой timeout маскирует провал enroll (essence redis: join_wait 10m + await 8m укладываются).
max_await_timeout: 10m

# VoyageWorker-пул (ADR-043): claim+execute унифицированных Voyage-прогонов
# (kind=scenario|command). Config-gated OFF по умолчанию (workers:0); включён
# для runtime-валидации пилота. poll_interval/lease_* опущены — берутся дефолты
# (DefaultVoyagePollInterval / DefaultVoyageLeaseTTL / DefaultVoyageLeaseRenewInterval).
voyage:
  workers: 2
  # max_scope — потолок размера резолвнутого scope одного Voyage (DoS-guard
  # S-med-3). Не задано → дефолт 10000; 0 → безлимит. Превышение → 422
  # voyage_scope_too_large.
  max_scope: 10000
  # max_batch_size — потолок размера батча/окна (DoS-guard S-W4): эффективный
  # batch_size для barrier, concurrency для window. Не задано → дефолт 10000;
  # 0 → без предела. Превышение → 422 voyage_batch_size_too_large.
  max_batch_size: 10000

reaper:
  enabled: true
  interval: 1h
  dry_run: false
  batch_size: 500
  lock_ttl: 5m
  rules:
    expire_pending_seeds: { enabled: true, max_age: 24h, action: delete }
    purge_used_tokens:    { enabled: true, max_age: 90d, action: delete }
    purge_souls:          { enabled: true, statuses: [disconnected, expired], max_age: 30d, action: delete }
    purge_old_seeds:      { enabled: true, statuses: [superseded, expired, revoked], max_age: 90d, action: delete }
    mark_disconnected:    { enabled: true, stale_after: 90s, action: set_status, target_status: disconnected }
    purge_audit_old:      { enabled: true, max_age: 365d, action: delete }
    purge_apply_runs:     { enabled: true, max_age: 30d, action: delete }
    purge_apply_task_register: { enabled: true, max_age: 1h, action: delete }
    reclaim_voyages:      { enabled: true, stale_after: 1m }

# Conductor — leader-elected исполнитель Cadence-расписаний (ADR-048). Свой
# lease `conductor:leader`, независимый от reaper.interval (1h). Спавн due-Cadence
# переехал сюда из Reaper-правила spawn_due_cadence.
#
# Адаптивный шаг опроса (ADR-048 «Adaptive interval»): шаг не фиксированный, а
# clamp(derivedMinPeriod, poll_floor, poll_ceiling); пустой реестр → poll_idle.
# derivedMinPeriod = MIN(interval_seconds) enabled-правил + 60s-вклад при наличии
# cron. Профиль «Спокойный» (floor=30s/ceiling=60s/idle=120s): Cadence с частым
# interval опрашивается у floor, редкие — у ceiling, пустой реестр — idle.
# floor=30s — абсолютный минимум (DB-CHECK floor interval_seconds ≥ 30 — Pass B).
# enabled опущено → default-ON при наличии Redis (footgun-guard ADR-048 §5);
# выключение отдельной Cadence — per-Cadence через её enabled: false, не тут.
cadence_scheduler:
  poll_floor: 30s
  poll_ceiling: 60s
  poll_idle: 120s
  lock_ttl: 5m

# RBAC-каталог — в Postgres (ADR-028), управление через role.* API/MCP;
# ключ `rbac:` в keeper.yml больше не принимается.

# push — bootstrap-доставка токена `core.bootstrap.delivered` (ADR-063) и
# push-прогон Destiny (ADR-032). Блок целиком опционален.
#
# transport (ADR-063 amendment) — режим bootstrap-доставки токена:
#   direct (default): generic SSH по primary_ip (Authorize/Sign плагина +
#     CA-signed host-cert verify через host_ca_refs[]).
#   teleport: by-name через Teleport Proxy (target = SID/FQDN, НЕ IP).
#     Транспорт+auth+host-verify целиком через Teleport identity-file;
#     Authorize/Sign плагина и Vault host-CA НЕ используются. Свежая VM
#     появляется в Teleport через ~3-5мин → модуль ретраит connect
#     (scenario-param join_wait_timeout, default 360s).
#
# Пример teleport-режима (закомментирован — dev-стенд без Teleport):
# push:
#   transport: teleport
#   teleport:
#     proxy_addr: proxy.example.com:443     # gRPC sshgrpc-listener Teleport Proxy
#     identity_file: /etc/soul/teleport-identity   # tctl auth sign, доступ к нодам
#     cluster: example.com                  # имя кластера, где резолвятся node-name (SID)

push:
  transport: teleport
  teleport:
    proxy_addr: tp.rwb.ru:443
    # dedicated: identity_file захардкожен в default dev-dir — параметризовать под STAND_DEV_DIR при полной изоляции (NIM-25).
    identity_file: /tmp/keeper-dev/keeper-push.identity
    cluster: teleport-rwb
    # proxy за публичным L7-TLS-балансировщиком (*.tp.rwb.ru), ADR-063 amendment;
    # use_system_trust — страховка при alpn off (при alpn_upgrade=true no-op)
    use_system_trust: true
    alpn_upgrade: true

# cloud-init userdata для core.cloud.provisioned (ADR-017(h));
# dev-стенд: bastion-туннель 192.168.2.3, CA в Vault (поле ca), artifact-хост :8443.
# dedicated: bootstrap_endpoint/soul_binary_url захардкожены на default dev — параметризовать при полной изоляции (NIM-25).
cloud_init:
  bootstrap_endpoint: "192.168.2.3:9442"
  # EventStream (mTLS) живёт на 9443 — без этого blueprint выводил оба порта
  # soul.yml из bootstrap_endpoint и soul dial-ил EventStream на 9442 (ADR-063).
  event_stream_port: 9443
  tls_ca_ref: "vault:secret/keeper/bootstrap-ca"
  soul_binary_url: "https://192.168.2.3:8443/soul"
